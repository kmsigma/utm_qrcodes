# Rename this file to .env and docker compose will pick it up automatically.

# The address and port the app listens on inside the container.
# Change the port mapping in docker-compose.yml if you change this.
ASPNETCORE_URLS=http://+:4278

# ASP.NET Core environment name. Controls logging verbosity and error detail.
# Use "Production" for live deployments and "Development" for local testing.
ASPNETCORE_ENVIRONMENT=Development
